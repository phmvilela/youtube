{
    "name": "YouTube Kids Dev Container",
    "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "./goose-feature": {},
        "./gemini-feature": {}
    },
    "mounts": [
        {
            "source": "${localEnv:HOME}/.config/goose", // Adjust path if needed
            "target": "/home/vscode/goose-config",
            "type": "bind"
        }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "google.gemini-cli-companion", // The bridge for Gemini CLI
                "Google.geminicodeassist"
            ]
        }
    },
    "forwardPorts": [5173],
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    // Inject your API Key from your Windows/WSL environment
    "remoteEnv": {
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
    },
    "remoteUser": "vscode",
    "containerUser": "vscode"
}
